# Environment Variables — copy this file to .env.local and fill in your values

# ─── Stripe Keys ──────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...          # Your Stripe secret key (starts with sk_live_ or sk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  # Your Stripe publishable key (starts with pk_live_ or pk_test_)

# ─── Stripe Webhook ───────────────────────────────────────────────────────────
# After deploying, go to https://dashboard.stripe.com/webhooks and add:
#   Endpoint URL: https://YOUR-DOMAIN.vercel.app/api/webhook
#   Events to listen: checkout.session.completed
# Then copy the "Signing secret" here:
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Admin Password ───────────────────────────────────────────────────────────
# Choose any password you want — you'll use this to log into /admin
ADMIN_PASSWORD=change-me-to-something-secure

# ─── Store Settings ───────────────────────────────────────────────────────────
NEXT_PUBLIC_STORE_NAME=Dave's 3D Fidgets
NEXT_PUBLIC_STORE_DESCRIPTION=Premium 3D Printed Fidget Toys

# ─── Shipping Countries ────────────────────────────────────────────────────────
# Comma-separated list of ISO 3166-1 alpha-2 country codes to ship to.
# Leave empty to use the default list (US, CA, GB, AU + major EU countries).
# Example: SHIPPING_COUNTRIES=US,CA,GB,AU
SHIPPING_COUNTRIES=
